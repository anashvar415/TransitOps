datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tripsCreated Trip[]
  driverProfile Driver?
}

model Vehicle {
  id                 String           @id @default(uuid())
  registrationNumber String           @unique
  name               String
  type               String
  maxLoadCapacityKg  Decimal
  odometerKm         Decimal
  acquisitionCost    Decimal
  status             VehicleStatus    @default(AVAILABLE)
  region             String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([region])
  @@index([type])
}

model Driver {
  id                 String       @id @default(uuid())
  name               String
  licenseNumber      String       @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String
  safetyScore        Int
  status             DriverStatus @default(AVAILABLE)
  userId             String?      @unique
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  trips              Trip[]

  @@index([status])
}

model Trip {
  id                 String       @id @default(uuid())
  source             String
  destination        String
  vehicleId          String
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id])
  driverId           String
  driver             Driver       @relation(fields: [driverId], references: [id])
  cargoWeightKg      Decimal
  plannedDistanceKm  Decimal
  actualDistanceKm   Decimal?
  fuelConsumedLiters Decimal?
  revenue            Decimal?
  status             TripStatus   @default(DRAFT)
  createdById        String
  createdBy          User         @relation(fields: [createdById], references: [id])
  dispatchedAt       DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  fuelLogs           FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id        String            @id @default(uuid())
  vehicleId String
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id])
  type      String
  cost      Decimal
  status    MaintenanceStatus @default(OPEN)
  openedAt  DateTime          @default(now())
  closedAt  DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  liters    Decimal
  cost      Decimal
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id        String   @id @default(uuid())
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  type      String
  amount    Decimal
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}
